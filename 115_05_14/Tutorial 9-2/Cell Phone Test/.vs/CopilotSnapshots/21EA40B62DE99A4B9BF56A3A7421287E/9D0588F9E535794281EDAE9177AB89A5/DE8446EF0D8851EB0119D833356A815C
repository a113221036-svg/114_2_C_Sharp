using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Cell_Phone_Test
{
    // CellPhone 類別用來表示一支手機的相關資訊
    class CellPhone
    {
        // 手機品牌屬性
        private string brand;
        
        // 手機型號屬性
        private string model;
        
        // 手機價格屬性
        private decimal price;

        // Brand 屬性的 getter 和 setter
        // 用來取得或設定手機的品牌名稱
        public string Brand
        {
            get { return brand; }
            set { brand = value; }
        }

        // Model 屬性的 getter 和 setter
        // 用來取得或設定手機的型號
        public string Model
        {
            get { return model; }
            set { model = value; }
        }

        // Price 屬性的 getter 和 setter
        // 用來取得或設定手機的價格
        public decimal Price
        {
            get { return price; }
            set { price = value; }
        }
    }
}

