using System;
using System.Linq;
using System.Windows.Forms;

namespace Review_Q3
{
    public partial class Form1 : Form
    {
        private Random rnd = new Random();
        private int[] generated = new int[5];

        public Form1()
        {
            InitializeComponent();
        }

        private void btnGenerate_Click(object sender, EventArgs e)
        {
            // generate 5 unique numbers between 1 and 49 for user's numbers
            var numbers = Enumerable.Range(1, 49).OrderBy(x => rnd.Next()).Take(5).ToArray();
            generated = numbers;
            txtNum1.Text = numbers[0].ToString();
            txtNum2.Text = numbers[1].ToString();
            txtNum3.Text = numbers[2].ToString();
            txtNum4.Text = numbers[3].ToString();
            txtNum5.Text = numbers[4].ToString();

            // clear previous comparison
            lblMatchCount.Text = string.Empty;
            lblMatchedNumbers.Text = string.Empty;
            txtResults.Clear();
        }

        private void btnDraw_Click(object sender, EventArgs e)
        {
            if (generated == null || generated.Length < 5 || generated.All(x => x == 0))
            {
                MessageBox.Show("請先按下 產生號碼。", "提示", MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            // generate 5 unique winning numbers between 1 and 49
            var drawn = Enumerable.Range(1, 49).OrderBy(x => rnd.Next()).Take(5).ToArray();

            // display drawn numbers in results area
            txtResults.Clear();
            txtResults.AppendText("本期開獎號碼：" + Environment.NewLine);
            for (int i = 0; i < drawn.Length; i++)
            {
                txtResults.AppendText($"第{ i + 1 }個號碼: { drawn[i] }" + Environment.NewLine);
            }

            // compare generated vs drawn
            var matches = generated.Intersect(drawn).OrderBy(x => x).ToArray();
            int count = matches.Length;

            if (count == 0)
            {
                lblMatchCount.Text = "未中獎";
                lblMatchedNumbers.Text = string.Empty;
            }
            else
            {
                lblMatchCount.Text = $"中{count}個號碼";
                lblMatchedNumbers.Text = "中獎號碼: " + string.Join(", ", matches);
            }
        }

        private void btnExit_Click(object sender, EventArgs e)
        {
            this.Close();
        }
    }
}
